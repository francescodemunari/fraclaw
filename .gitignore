# 🦅 FRACLAW - GitHub IGNORE LIST

# --- Python ---
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# --- Environment & Sensitive Data ---
.env
.env.local
.env.*.local
*.db
*.db-journal
*.sqlite

# --- Node.js & React Frontend ---
webapp/node_modules/
webapp/dist/
webapp/.svelte-kit/
webapp/.next/
.eslintcache

# --- Data & Workspace (Ignore ALL personal/runtime content) ---
data/**/*
!data/
!data/**/
!data/.gitkeep
!data/voices/default_ref.wav

# Explicitly exclude common dynamic files
*.db
*.db-journal
*.sqlite3
data/*.md
data/*.log
# --- IDE & System ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
