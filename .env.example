# ============================================================
# FRACLAW — Configuration
# ============================================================

# --- Telegram ---
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_token_here
# Your numerical User ID (get it from @userinfobot)
TELEGRAM_ALLOWED_USER_ID=your_id_here

# --- LM Studio ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_URL=http://localhost:1234
LM_STUDIO_MODEL=model

# --- ComfyUI ---
# ComfyUI address (must be running for image generation)
COMFYUI_URL=http://127.0.0.1:8188
# EXACT name of the checkpoint file in ComfyUI/models/checkpoints/
COMFYUI_MODEL=your_model.safetensors
VRAM_MODE=exclusive

# --- Filesystem ---
# Authorized directory paths for the AI (comma-separated)
FILESYSTEM_ALLOWED_PATHS=C:\Users\User\Documents

# --- Whisper ---
# Voice transcription model (tiny, base, small, medium, large-v2)
WHISPER_MODEL=base

# --- Database ---
DB_PATH=data/fraclaw.db
CHROMA_PATH=data/chroma
