# ============================================================
# FRACLAW — Configuration
# ============================================================

# --- Telegram ---
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_numeric_id_here

# --- LM Studio ---
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_URL=http://localhost:1234
LLM_MODEL_BASE=qwen/qwen3.5-9b
LLM_MODEL_CODER=qwen2.5-coder-7b-instruct

# --- ComfyUI ---
# ComfyUI address (must be running for image generation)
COMFYUI_URL=http://127.0.0.1:8188
# EXACT name of the checkpoint file in ComfyUI/models/checkpoints/
COMFYUI_MODEL=dreamshaperXL_lightningDPMSDE.safetensors
VRAM_MODE=exclusive

# --- Filesystem ---
# Authorized directory paths for the AI (comma-separated)
FILESYSTEM_ALLOWED_PATHS=C:\path\to\your\workspace

# --- Whisper ---
# Voice transcription model (tiny, base, small, medium, large-v2)
WHISPER_MODEL=base

# --- Database ---
DB_PATH=data/fraclaw.db
CHROMA_PATH=data/chroma
