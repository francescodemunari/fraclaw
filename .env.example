# ============================================================
# FRACLAW v1.2 — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file — it contains secrets.

# ── Active Provider ──────────────────────────────────────────
# Which LLM backend to use. Options:
#   lm_studio, openrouter, anthropic, openai, deepseek, ollama, gemini
ACTIVE_PROVIDER=lm_studio

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=0

# ── Discord (Optional) ──────────────────────────────────────
# DISCORD_TOKEN=your_discord_bot_token_here
# DISCORD_ALLOWED_USER_IDS=123456789,987654321

# ── WhatsApp (Optional) ─────────────────────────────────────
# WHATSAPP_ENABLED=false

# ── LM Studio (Local) ───────────────────────────────────────
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_URL=http://localhost:1234
LLM_MODEL_BASE=qwen/qwen3.5-9b
LLM_MODEL_CODER=qwen2.5-coder-7b-instruct

# ── Ollama (Local Alternative) ──────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b

# ── Cloud Provider API Keys ─────────────────────────────────
# Only fill in the ones you plan to use.
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# ── ComfyUI (Image Generation) ──────────────────────────────
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_MODEL=juggernautXL_v9Rundiffusion.safetensors
VRAM_MODE=exclusive

# ── Filesystem ───────────────────────────────────────────────
FILESYSTEM_ALLOWED_PATHS=C:\Users\Admin

# ── Whisper (Voice Transcription) ────────────────────────────
WHISPER_MODEL=base

# ── Agent Behaviour ──────────────────────────────────────────
HISTORY_LIMIT=25

# ── Database ─────────────────────────────────────────────────
DB_PATH=data/fraclaw.db
CHROMA_PATH=data/chroma
