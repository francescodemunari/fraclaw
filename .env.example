#  FRACLAW - Environment Configuration Example
# Copy this file to .env and fill in your values.

# ---  Telegram Bot Configuration ---
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
# Your numerical Telegram ID (Get it from @userinfobot)
TELEGRAM_ALLOWED_USER_ID=123456789

# ---  LLM Server (LM Studio) ---
LM_STUDIO_API_URL=http://localhost:1234
# Names of the models as seen in LM Studio
LLM_MODEL_BASE=qwen2.5-14b-instruct
LLM_MODEL_CODER=qwen2.5-coder-14b-instruct

# ---  Audio Settings ---
# DEFAULT_PREMIUM_VOICE: Set to true to attempt Chatterbox cloning by default
DEFAULT_PREMIUM_VOICE=true
# Faster-Whisper model (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# ---  Image Generation (ComfyUI) ---
COMFYUI_URL=http://localhost:8188
COMFYUI_MODEL=Juggernaut_XL_v9.safetensors
# VRAM_MODE: Use 'exclusive' to unload LLM before generating images (recommended for <16GB VRAM)
VRAM_MODE=exclusive

# ---  Network & Remote Access ---
# Use localhost or your Tailscale IP
BACKEND_HOST=localhost
PORT=8000

# ---  Storage Paths ---
DB_PATH=data/memory.db
CHROMA_PATH=data/chroma
WORKSPACE_DIR=data/workspace
OUTPUT_DIR=data/output
UPLOAD_DIR=data/uploads
VOICES_DIR=data/voices
