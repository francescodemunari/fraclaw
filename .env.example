# 🦅 FRACLAW - Environment Configuration Example
# Copy this file to .env and fill in your values.

# --- 🤖 Telegram Bot Configuration ---
# Get your token from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your numerical Telegram ID (Get it from @userinfobot)
TELEGRAM_ALLOWED_USER_ID=123456789

# --- 🧠 LLM Server (LM Studio) ---
# Default LM Studio local server URL
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# --- 🎙️ Audio Settings ---
# Enable/Disable voice cloning support by default
DEFAULT_PREMIUM_VOICE=true

# --- 🌍 Network & Remote Access ---
# If using Tailscale, you can set the host here (optional)
BACKEND_HOST=localhost
PORT=8000

# --- 📓 Memory & Storage ---
# Path to the persistent SQLite database
DB_PATH=data/memory.db
WORKSPACE_DIR=data/workspace
OUTPUT_DIR=data/output
UPLOAD_DIR=data/uploads
VOICES_DIR=data/voices
